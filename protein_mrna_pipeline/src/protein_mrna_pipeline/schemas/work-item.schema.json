{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/protein-mrna-pipeline/work-item.schema.json",
  "title": "Protein-to-mRNA Pipeline Work Item",
  "type": "object",
  "required": [
    "schema_version",
    "target_id",
    "target_sha256",
    "execution_class",
    "stage",
    "tool",
    "parameters",
    "seed",
    "priority",
    "max_attempts",
    "inputs"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "protein-mrna.work-item.v1"},
    "work_id": {"$ref": "#/$defs/id"},
    "target_id": {"$ref": "#/$defs/id"},
    "target_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_id": {"$ref": "#/$defs/id"},
    "execution_class": {"enum": ["smoke", "formal"]},
    "stage": {
      "enum": [
        "initial_fold",
        "mpnn_design",
        "refold",
        "structure_metrics",
        "mrna_generate",
        "mrna_score",
        "surrogate_score",
        "recompute"
      ]
    },
    "tool": {"$ref": "#/$defs/tool"},
    "parameters": {"type": "object"},
    "seed": {"type": "integer", "minimum": 0},
    "priority": {"type": "integer", "minimum": -1000, "maximum": 1000},
    "max_attempts": {"type": "integer", "minimum": 1, "maximum": 10},
    "inputs": {
      "type": "array",
      "items": {"$ref": "#/$defs/artifact"}
    },
    "created_at_utc": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "tool": {
      "type": "object",
      "required": ["name", "kind", "revision", "weights_sha256", "environment_id"],
      "properties": {
        "name": {"$ref": "#/$defs/id"},
        "kind": {
          "enum": ["structure", "protein_design", "mrna_model", "rule", "other"]
        },
        "revision": {"type": "string", "minLength": 1},
        "weights_sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        },
        "environment_id": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {"enum": ["structure", "protein_design", "mrna_model"]}
            }
          },
          "then": {
            "properties": {
              "weights_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["artifact_id", "path", "sha256", "bytes", "media_type"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/id"},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "bytes": {"type": "integer", "minimum": 0},
        "media_type": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  }
}
