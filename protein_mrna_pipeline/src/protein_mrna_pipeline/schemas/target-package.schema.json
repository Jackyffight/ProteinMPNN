{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/protein-mrna-pipeline/target-package.schema.json",
  "title": "Protein-to-mRNA Target Package",
  "type": "object",
  "required": [
    "schema_version",
    "target_id",
    "revision",
    "display_name",
    "domains",
    "architecture",
    "design_constraints",
    "expression",
    "safety",
    "metadata"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "protein-mrna.target-package.v1"},
    "target_id": {"$ref": "#/$defs/id"},
    "revision": {"type": "integer", "minimum": 1},
    "display_name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/domain"}
    },
    "architecture": {"$ref": "#/$defs/architecture"},
    "design_constraints": {"$ref": "#/$defs/design_constraints"},
    "expression": {"$ref": "#/$defs/expression"},
    "safety": {"$ref": "#/$defs/safety"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "region": {
      "type": "object",
      "required": ["domain_id", "start", "end"],
      "properties": {
        "domain_id": {"$ref": "#/$defs/id"},
        "start": {"type": "integer", "minimum": 1},
        "end": {"type": "integer", "minimum": 1},
        "label": {"type": "string"}
      },
      "additionalProperties": false
    },
    "reference_structure": {
      "type": "object",
      "required": ["path", "sha256", "format"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "format": {"enum": ["pdb", "mmcif"]},
        "chain_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "domain": {
      "type": "object",
      "required": [
        "domain_id",
        "role",
        "amino_acid_sequence",
        "immutable_regions"
      ],
      "properties": {
        "domain_id": {"$ref": "#/$defs/id"},
        "role": {
          "enum": [
            "antigen",
            "binding",
            "effector",
            "scaffold",
            "tag",
            "other"
          ]
        },
        "amino_acid_sequence": {
          "type": "string",
          "pattern": "^[ACDEFGHIKLMNPQRSTVWYX]+$",
          "minLength": 1
        },
        "immutable_regions": {
          "type": "array",
          "items": {"$ref": "#/$defs/region"}
        },
        "reference_structure": {"$ref": "#/$defs/reference_structure"},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    },
    "linker": {
      "type": "object",
      "required": [
        "linker_id",
        "between",
        "family",
        "min_length",
        "max_length"
      ],
      "properties": {
        "linker_id": {"$ref": "#/$defs/id"},
        "between": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/id"}
        },
        "family": {"type": "string", "minLength": 1},
        "min_length": {"type": "integer", "minimum": 0},
        "max_length": {"type": "integer", "minimum": 0},
        "allowed_sequences": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[ACDEFGHIKLMNPQRSTVWY]+$"
          }
        }
      },
      "additionalProperties": false
    },
    "architecture": {
      "type": "object",
      "required": [
        "allowed_domain_orders",
        "linker_options",
        "allow_direct_fusion",
        "oligomeric_state",
        "maximum_total_length"
      ],
      "properties": {
        "allowed_domain_orders": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/id"}
          }
        },
        "linker_options": {
          "type": "array",
          "items": {"$ref": "#/$defs/linker"}
        },
        "allow_direct_fusion": {"type": "boolean"},
        "oligomeric_state": {
          "enum": ["monomer", "homomer", "heteromer", "unspecified"]
        },
        "maximum_total_length": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "design_constraints": {
      "type": "object",
      "required": [
        "fixed_regions",
        "mutable_regions",
        "forbidden_motifs",
        "prohibited_modifications"
      ],
      "properties": {
        "fixed_regions": {
          "type": "array",
          "items": {"$ref": "#/$defs/region"}
        },
        "mutable_regions": {
          "type": "array",
          "items": {"$ref": "#/$defs/region"}
        },
        "forbidden_motifs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "prohibited_modifications": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "expression": {
      "type": "object",
      "required": ["host", "purification_tags"],
      "properties": {
        "host": {"type": "string", "minLength": 1},
        "purification_tags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": ["status", "prohibited_modifications"],
      "properties": {
        "status": {
          "enum": ["not_reviewed", "in_review", "approved", "denied"]
        },
        "review_id": {"type": "string", "minLength": 1},
        "reviewed_by": {"type": "string", "minLength": 1},
        "reviewed_at_utc": {"type": "string", "format": "date-time"},
        "notes": {"type": "string"},
        "prohibited_modifications": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "approved"}}},
          "then": {
            "required": ["review_id", "reviewed_by", "reviewed_at_utc"]
          }
        }
      ],
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": ["owner", "created_at_utc", "source_references"],
      "properties": {
        "owner": {"type": "string", "minLength": 1},
        "created_at_utc": {"type": "string", "format": "date-time"},
        "source_references": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
