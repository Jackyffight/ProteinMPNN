{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/proteinmpnn/design_manifest.schema.json",
  "title": "ProteinMPNN to mRNABERT Design Manifest Row",
  "type": "object",
  "required": [
    "design_id",
    "target_id",
    "backbone_id",
    "designed_chains",
    "mpnn_checkpoint",
    "mpnn_params",
    "protein_sequence",
    "mrna_objective"
  ],
  "properties": {
    "design_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "backbone_id": {
      "type": "string",
      "minLength": 1
    },
    "axis_method": {
      "type": "string",
      "enum": ["pca_ca", "pca", "inertia", "interface_normal", "anchor", "custom"],
      "description": "Geometry-axis method. Controlled vocabulary shared with the mRNABERT design pipeline (mRNABERT docs/reports/protein-mrna-design-pipeline.md lists PCA/inertia/interface_normal/anchor/custom); pca_ca = PCA over CA atoms."
    },
    "axis_vector": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    },
    "anchor_residues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/residue_ref"
      }
    },
    "fixed_positions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/residue_ref"
      }
    },
    "designed_chains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mpnn_checkpoint": {
      "type": "string",
      "minLength": 1
    },
    "mpnn_params": {
      "type": "object",
      "properties": {
        "num_neighbors": {
          "type": "integer",
          "minimum": 1
        },
        "backbone_noise": {
          "type": "number",
          "minimum": 0
        },
        "temperature": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "protein_sequence": {
      "type": "string",
      "pattern": "^[ACDEFGHIKLMNPQRSTVWYX]+$"
    },
    "mpnn_score": {
      "type": "number"
    },
    "fold2_revision": {
      "type": "string"
    },
    "fold2_metrics": {
      "type": "object",
      "properties": {
        "plddt_mean": {
          "type": "number"
        },
        "ptm": {
          "type": "number"
        },
        "iptm": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "mrna_objective": {
      "type": "object",
      "required": ["species", "cds_policy"],
      "properties": {
        "species": {
          "type": "string",
          "minLength": 1
        },
        "utr_policy": {
          "type": "string"
        },
        "cds_policy": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "residue_ref": {
      "type": "object",
      "required": ["chain", "residue"],
      "properties": {
        "chain": {
          "type": "string",
          "minLength": 1
        },
        "residue": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  }
}
